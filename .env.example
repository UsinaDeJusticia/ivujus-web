# Base de datos (Neon Postgres)
DATABASE_URI=postgres://usuario:password@host/db?sslmode=require

# Payload
PAYLOAD_SECRET=cadena-larga-aleatoria-al-menos-32-chars
PAYLOAD_PUBLIC_SERVER_URL=https://ivujus.org.ar

# Anthropic (traducción automática)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (fallback económico para traducción batch)
OPENROUTER_API_KEY=sk-or-...

# Almacenamiento de medios — elegir uno
# Opción 1: Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Opción 2: Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ivujus-media

# Correo transaccional
RESEND_API_KEY=

# Newsletter Perfit (existente, no se migra)
PERFIT_SUBSCRIBE_URL=https://optin.myperfit.com/subscribe/usinadejusticia/RUknaImy

# WordPress (solo para fase de migración)
WP_IVUJUS_API=https://ivujus.org.ar/wp-json/wp/v2
WP_USINA_API=https://usinadejusticia.org.ar/wp-json/wp/v2

# Feature flags
ENABLE_AUTO_TRANSLATION=true
ENABLE_AGENT_API=false
